---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getGlossaryRobots } from "../../lib/content-governance";

const siteName = import.meta.env.PUBLIC_SITE_NAME ?? "PricingNest";
const entries = await getCollection("glossary");
const indexedEntries = entries.filter((entry) => getGlossaryRobots(entry.slug) === "index,follow");
const termMap = new Map(
  indexedEntries.map((entry) => [
    entry.slug,
    { slug: entry.slug, href: `/glossary/${entry.slug}/`, title: entry.data.title, description: entry.data.description }
  ])
);

function pickTerms(slugs: string[]) {
  return slugs.map((slug) => termMap.get(slug)).filter(Boolean);
}

const apiTerms = pickTerms([
  "api-call",
  "rate-limit",
  "overage"
]);

const storageTerms = pickTerms([
  "gb-month",
  "minimum-commitment",
  "gross-margin"
]);

const usageTerms = pickTerms([
  "value-metric",
  "usage-based-pricing",
  "overage"
]);

const computeTerms = pickTerms([
  "gross-margin",
  "unit-cost",
  "minimum-commitment",
  "included-usage"
]);

---
<BaseLayout
  title={`Glossary | ${siteName}`}
  description="Curated definitions for the SaaS pricing, packaging, and unit-economics terms used across PricingNest."
>
  <section class="hero">
    <h1>Glossary</h1>
    <p>Learn only the language you need before opening the matching calculator or guide path.</p>
  </section>

  <div class="grid">
    <section class="card col8">
      <h2>Four retained glossary paths</h2>
      <p class="muted">Start with the smallest set of terms that will help you read the next calculator or guide with less noise.</p>
      <div class="feature-grid" style="margin-top: 1rem;">
        <div class="feature col6">
          <h3>API pricing terms</h3>
          <ul class="list">
            {apiTerms.map((term) => (
              <li><a href={term.href}>{term.title}</a></li>
            ))}
          </ul>
        </div>
        <div class="feature col6">
          <h3>Storage pricing terms</h3>
          <ul class="list">
            {storageTerms.map((term) => (
              <li><a href={term.href}>{term.title}</a></li>
            ))}
          </ul>
        </div>
        <div class="feature col6">
          <h3>Usage pricing terms</h3>
          <ul class="list">
            {usageTerms.map((term) => (
              <li><a href={term.href}>{term.title}</a></li>
            ))}
          </ul>
        </div>
        <div class="feature col6">
          <h3>Compute pricing terms</h3>
          <ul class="list">
            {computeTerms.map((term) => (
              <li><a href={term.href}>{term.title}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <aside class="card col4">
      <h2>Use the toolkit</h2>
      <ul class="list">
        <li><a href="/saas-pricing/">All calculators</a></li>
        <li><a href="/guides/">Guides</a></li>
        <li><a href="/about/">About the methodology</a></li>
      </ul>

      <h2 style="margin-top: 1.25rem;">How to use this hub</h2>
      <ul class="list">
        <li>Start with the path that matches API, storage, usage, or compute pricing.</li>
        <li>Move into a guide when you need decision criteria, not another definition.</li>
        <li>Use these terms to clarify one blocker, not to browse the full inventory.</li>
      </ul>
    </aside>
  </div>
</BaseLayout>
