---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getGlossaryRobots } from "../../lib/content-governance";

const siteName = import.meta.env.PUBLIC_SITE_NAME ?? "PricingNest";
const entries = await getCollection("glossary");
const indexedEntries = entries.filter((entry) => getGlossaryRobots(entry.slug) === "index,follow");
const termMap = new Map(
  indexedEntries.map((entry) => [
    entry.slug,
    { slug: entry.slug, href: `/glossary/${entry.slug}/`, title: entry.data.title, description: entry.data.description }
  ])
);

function pickTerms(slugs: string[]) {
  return slugs.map((slug) => termMap.get(slug)).filter(Boolean);
}

const keyTerms = pickTerms([
  "value-metric",
  "usage-based-pricing",
  "annual-prepay-discount",
  "gross-margin",
  "churn"
]);

const pricingMechanicsTerms = pickTerms([
  "pricing-metric",
  "rate-limit",
  "included-usage",
  "gb-month",
  "storage-costs"
]);

const unitEconomicsTerms = pickTerms([
  "cogs",
  "unit-cost",
  "support-costs",
  "usage-forecast",
  "churn"
]);

---
<BaseLayout
  title={`Glossary | ${siteName}`}
  description="Curated definitions for the SaaS pricing, packaging, and unit-economics terms used across PricingNest."
>
  <section class="hero">
    <h1>Glossary</h1>
    <p>Learn the core terms first, then move into the calculators and guides with clearer context and less noise.</p>
  </section>

  <div class="grid">
    <section class="card col8">
      <h2>Key terms to learn first</h2>
      <p class="muted">Start here if you are new to SaaS pricing or need a quick reset before modeling a decision.</p>
      <div class="tools" style="margin-top: 0.9rem;">
        {keyTerms.map((term) => (
          <a class="tool" href={term.href}>
            <strong>{term.title}</strong>
            <span>{term.description}</span>
          </a>
        ))}
      </div>

      <h2 style="margin-top: 1.25rem;">Pricing mechanics</h2>
      <p class="muted">These terms explain how plans are packaged, billed, and protected against margin leakage.</p>
      <div class="tools" style="margin-top: 0.9rem;">
        {pricingMechanicsTerms.map((term) => (
          <a class="tool" href={term.href}>
            <strong>{term.title}</strong>
            <span>{term.description}</span>
          </a>
        ))}
      </div>

      <h2 style="margin-top: 1.25rem;">Unit economics and retention</h2>
      <p class="muted">Use these when pricing choices affect annual contracts, support load, or retention risk.</p>
      <div class="tools" style="margin-top: 0.9rem;">
        {unitEconomicsTerms.map((term) => (
          <a class="tool" href={term.href}>
            <strong>{term.title}</strong>
            <span>{term.description}</span>
          </a>
        ))}
      </div>
    </section>

    <aside class="card col4">
      <h2>Use the toolkit</h2>
      <ul class="list">
        <li><a href="/saas-pricing/">All calculators</a></li>
        <li><a href="/guides/">Guides</a></li>
        <li><a href="/about/">About the methodology</a></li>
      </ul>

      <h2 style="margin-top: 1.25rem;">How to use this hub</h2>
      <ul class="list">
        <li>Start with one key term before jumping into a calculator.</li>
        <li>Move into a guide when you need decision criteria, not just a definition.</li>
        <li>Use these terms to clarify pricing language, not to browse the whole inventory.</li>
      </ul>
    </aside>
  </div>
</BaseLayout>
