---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getToolBySlug, getToolName } from "../../lib/tools";
import { getGlossaryRobots, getGuideRobots } from "../../lib/content-governance";

export async function getStaticPaths() {
  const entries = await getCollection("glossary");
  return entries.map((entry) => ({ params: { slug: entry.slug } }));
}

const siteName = import.meta.env.PUBLIC_SITE_NAME ?? "PricingNest";
const { slug } = Astro.params as { slug: string };
const glossaryEntries = await getCollection("glossary");
const guideEntries = await getCollection("guides");
const entry = glossaryEntries.find((e) => e.slug === slug);
if (!entry) throw new Error(`Unknown glossary slug: ${slug}`);

const { Content } = await entry.render();
const title = `${entry.data.title} | ${siteName}`;

const relatedToolSlugs = entry.data.tools ?? [];
const relatedGuideSlugs = entry.data.guides ?? [];
const relatedGlossarySlugs = entry.data.glossary ?? [];

const relatedTools = relatedToolSlugs
  .map((toolSlug) => getToolBySlug(toolSlug))
  .filter(Boolean)
  // @ts-expect-error
  .map((tool) => ({ href: `/saas-pricing/${tool.slug}/`, label: getToolName(tool) }));

const guideTitleMap = new Map(guideEntries.map((guide) => [guide.slug, guide.data.title]));
const glossaryTitleMap = new Map(glossaryEntries.map((term) => [term.slug, term.data.title]));
const relatedGuides = relatedGuideSlugs
  .filter((guideSlug) => getGuideRobots(guideSlug) === "index,follow")
  .map((guideSlug) => {
    const label = guideTitleMap.get(guideSlug);
    if (!label) return null;
    return { href: `/guides/${guideSlug}/`, label };
  })
  .filter(Boolean);

const relatedGlossary = relatedGlossarySlugs
  .filter((termSlug) => getGlossaryRobots(termSlug) === "index,follow")
  .map((termSlug) => {
    const label = glossaryTitleMap.get(termSlug);
    if (!label) return null;
    return { href: `/glossary/${termSlug}/`, label };
  })
  .filter(Boolean);
const robots = getGlossaryRobots(entry.slug);
const siteUrl = (Astro.site?.toString() ?? import.meta.env.PUBLIC_SITE_URL ?? "https://pricingnest.com").replace(/\/$/, "");
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const editorialTeamHref = "/about/#editorial-team";
const reviewPolicyHref = "/about/#review-policy";
const authorName = entry.data.author ?? "PricingNest Editorial Team";
const reviewedBy = entry.data.reviewedBy ?? "PricingNest Editorial Team";
const published = entry.data.published ?? entry.data.updated;
const updated = entry.data.updated ?? published;
const reviewed = entry.data.reviewed ?? updated;
type GlossarySource = NonNullable<typeof entry.data.sources>[number];
const glossarySources = entry.data.sources ?? [];
const termJsonLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: entry.data.title,
  description: entry.data.description,
  url: canonical,
  inDefinedTermSet: new URL("/glossary/", siteUrl).toString(),
  ...(updated ? { dateModified: updated } : {})
};

function isExternalHref(value: string): boolean {
  return /^https?:\/\//i.test(value);
}

function formatGlossarySourceKind(kind: GlossarySource["kind"]): string {
  if (kind === "internal-input") return "Internal input";
  if (kind === "supporting-page") return "Supporting page";
  return "External reference";
}
---
<BaseLayout title={title} description={entry.data.description} robots={robots}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(termJsonLd)} />
  <section class="hero">
    <h1>{entry.data.title}</h1>
    <p>{entry.data.description}</p>
  </section>

  <div class="grid">
    <article class="card col8">
      <Content />
    </article>

    <aside class="card col4">
      <h2>Methodology and review</h2>
      <ul class="list">
        <li><strong>Author:</strong> <a href={editorialTeamHref}>{authorName}</a></li>
        <li><strong>Reviewed by:</strong> <a href={reviewPolicyHref}>{reviewedBy}</a></li>
        {published ? <li><strong>Published:</strong> {published}</li> : null}
        {reviewed ? <li><strong>Reviewed:</strong> {reviewed}</li> : null}
      </ul>
      <p class="muted" style="margin-top: 0.75rem;">
        PricingNest Editorial Team reviews glossary entries for definition clarity, consistent usage, and links to
        related tools or guides.
      </p>
      <p class="muted" style="margin-top: 0.75rem;">
        See the <a href={editorialTeamHref}>editorial responsibility</a> and <a href={reviewPolicyHref}>review policy</a>
        for how retained pages are updated.
      </p>

      {glossarySources.length > 0 ? (
        <>
          <h2 style="margin-top: 1.25rem;">Sources and references</h2>
          <div class="source-list">
            {glossarySources.map((source) => (
              <div class="source-item">
                <div class="source-item-head">
                  <span class="badge source-kind">{formatGlossarySourceKind(source.kind)}</span>
                </div>
                <div class="source-item-body">
                  {source.href ? (
                    isExternalHref(source.href) ? (
                      <a class="source-link" href={source.href} rel="noopener noreferrer" target="_blank">
                        <strong>{source.label}</strong>
                      </a>
                    ) : (
                      <a class="source-link" href={source.href}>
                        <strong>{source.label}</strong>
                      </a>
                    )
                  ) : (
                    <strong>{source.label}</strong>
                  )}
                  {source.note ? <p class="muted source-note">{source.note}</p> : null}
                </div>
              </div>
            ))}
          </div>
        </>
      ) : null}

      {(relatedTools.length > 0 || relatedGuides.length > 0 || relatedGlossary.length > 0) ? (
        <>
          <h2 style="margin-top: 1.25rem;">Recommended next steps</h2>
          {relatedTools.length > 0 ? (
            <>
              <p class="muted" style="margin-top: 0.5rem;">Run a calculator that uses this concept directly.</p>
              <ul class="list">
                {relatedTools.map((t) => (
                  <li><a href={t.href}>{t.label}</a></li>
                ))}
              </ul>
            </>
          ) : null}
          {relatedGuides.length > 0 ? (
            <>
              <p class="muted" style="margin-top: 0.85rem;">Read the decision guide where this term matters in practice.</p>
              <ul class="list">
                {relatedGuides.map((g) => (
                  <li><a href={g?.href}>{g?.label}</a></li>
                ))}
              </ul>
            </>
          ) : null}
          {relatedGlossary.length > 0 ? (
            <>
              <p class="muted" style="margin-top: 0.85rem;">Review adjacent terms if you need more context.</p>
              <ul class="list">
                {relatedGlossary.map((g) => (
                  <li><a href={g?.href}>{g?.label}</a></li>
                ))}
              </ul>
            </>
          ) : null}
        </>
      ) : null}

      <h2 style="margin-top: 1.25rem;">Use the toolkit</h2>
      <ul class="list">
        <li><a href="/saas-pricing/">All calculators</a></li>
        <li><a href="/guides/">Guides</a></li>
        <li><a href="/glossary/">All glossary terms</a></li>
        <li><a href="/about/">About the methodology</a></li>
        <li><a href="/contact/">Report a correction</a></li>
      </ul>

      {updated ? <p class="muted" style="margin-top: 1rem;">Last updated: {updated}</p> : null}
    </aside>
  </div>
</BaseLayout>
