---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolCard from "../../components/ToolCard.astro";
import { TOOLS, getPriorityTools } from "../../lib/tools";

const siteUrl = (Astro.site?.toString() ?? import.meta.env.PUBLIC_SITE_URL ?? "https://pricingnest.com").replace(/\/$/, "");
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const featuredTools = getPriorityTools(TOOLS);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: featuredTools.map((t, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: t.title,
    url: new URL(`/saas-pricing/${t.slug}/`, siteUrl).toString()
  })),
  url: canonical
};
---
<BaseLayout
  title="SaaS Pricing Calculator Toolkit - Free Cost & Margin Calculators | PricingNest"
  description="Free SaaS pricing calculator toolkit with usage-based pricing, API pricing, storage and compute cost calculators, plus margin modeling."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <section class="hero">
    <h1>SaaS Pricing Toolkit</h1>
    <p>
      A focused set of pricing and cost estimators. Enter your own costs, usage, and margins to get a clear breakdown you
      can share.
    </p>
    <div class="btn-row">
      <a class="btn primary" href="/saas-pricing/storage-cost-calculator/">Open cost per GB calculator</a>
      <a class="btn ghost" href="/saas-pricing/api-pricing-calculator/">Open API cost calculator</a>
    </div>
    <div class="pill-row" aria-label="Highlights">
      <span class="pill">Transparent inputs</span>
      <span class="pill">Scenario presets</span>
      <span class="pill">Export + share</span>
    </div>
  </section>

  <div class="grid">
    <section class="card col8">
      <h2>Tools</h2>
      <div class="tools">
        {featuredTools.map((tool) => (
          <ToolCard tool={tool} />
        ))}
      </div>
    </section>
    <aside class="card col4">
      <h2>How to use</h2>
      <p class="muted">
        Pick a tool, enter your assumptions, then copy a shareable link for your team. We don't fetch live cloud pricing,
        so you control the model.
      </p>
      <h2 style="margin-top: 1.1rem;">What's included</h2>
      <ul class="list">
        <li>Presets to start fast</li>
        <li>Shareable URLs for collaboration</li>
        <li>CSV export for spreadsheets</li>
      </ul>
      <h2 style="margin-top: 1.1rem;">Use cases</h2>
      <ul class="list">
        <li><a href="/saas-pricing/use-cases/">All use cases</a></li>
        <li><a href="/saas-pricing/use-cases/usage-based-pricing/">Usage-based pricing</a></li>
        <li><a href="/saas-pricing/use-cases/api-pricing/">API pricing</a></li>
        <li><a href="/saas-pricing/use-cases/infra-cost-recovery/">Infra cost recovery</a></li>
        <li><a href="/saas-pricing/use-cases/unit-economics/">SaaS unit economics</a></li>
        <li><a href="/saas-pricing/use-cases/pricing-experiments/">Pricing experiments</a></li>
      </ul>
    </aside>
  </div>

  <section class="card" style="margin-top: 1rem;">
    <h2>Five core calculator workflows</h2>
    <p class="muted">Start with the workflow closest to your pricing decision. Each path points to one calculator cluster and a smaller retained reading path.</p>
    <div class="feature-grid" style="margin-top: 0.9rem;">
      <div class="feature col6">
        <h3>Usage-based pricing</h3>
        <ol class="list">
          <li><a href="/saas-pricing/usage-based-pricing-calculator/">Set a baseline price per unit</a></li>
          <li><a href="/guides/value-metric-selection/">Choose a value metric buyers can follow</a></li>
          <li><a href="/guides/usage-based-pricing-examples/">Review concrete packaging examples</a></li>
        </ol>
      </div>
      <div class="feature col6">
        <h3>API pricing</h3>
        <ol class="list">
          <li><a href="/saas-pricing/api-pricing-calculator/">Estimate price per 1,000 calls</a></li>
          <li><a href="/guides/api-cost-estimation/">Review API cost inputs and guardrails</a></li>
          <li><a href="/guides/api-pricing-model/">Choose the right API packaging model</a></li>
        </ol>
      </div>
      <div class="feature col6">
        <h3>Storage pricing</h3>
        <ol class="list">
          <li><a href="/saas-pricing/storage-cost-calculator/">Estimate cost per GB</a></li>
          <li><a href="/guides/storage-costs-and-pricing/">Match storage cost structure to pricing</a></li>
          <li><a href="/guides/storage-retrieval-fees/">Check when retrieval fees need separate treatment</a></li>
        </ol>
      </div>
      <div class="feature col6">
        <h3>Compute pricing</h3>
        <ol class="list">
          <li><a href="/saas-pricing/compute-cost-estimator/">Back into a margin-safe compute price</a></li>
          <li><a href="/guides/compute-cost-modeling/">Model the cost drivers behind the estimate</a></li>
          <li><a href="/guides/monthly-cloud-cost-breakdown/">Review the monthly cloud cost breakdown</a></li>
        </ol>
      </div>
      <div class="feature col6">
        <h3>Annual pricing and discounts</h3>
        <ol class="list">
          <li><a href="/saas-pricing/annual-discount-calculator/">Compare annual pricing scenarios</a></li>
          <li><a href="/guides/annual-prepay-discount/">Set annual discount guardrails</a></li>
          <li><a href="/saas-pricing/pricing-increase-impact-calculator/">Model grandfathering scenarios</a></li>
        </ol>
      </div>
    </div>
  </section>
</BaseLayout>
