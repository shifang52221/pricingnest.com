---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getGuideRobots } from "../../lib/content-governance";

const siteName = import.meta.env.PUBLIC_SITE_NAME ?? "PricingNest";
const entries = await getCollection("guides");
const indexedEntries = entries.filter((entry) => getGuideRobots(entry.slug) === "index,follow");
const guideMap = new Map(
  indexedEntries.map((entry) => [
    entry.slug,
    { slug: entry.slug, href: `/guides/${entry.slug}/`, title: entry.data.title, description: entry.data.description }
  ])
);

function pickGuides(slugs: string[]) {
  return slugs.map((slug) => guideMap.get(slug)).filter(Boolean);
}

const featuredDecisionGuides = pickGuides([
  "usage-based-pricing-examples",
  "api-cost-estimation",
  "storage-costs-and-pricing",
  "compute-cost-modeling"
]);

const usagePathGuides = pickGuides([
  "usage-based-pricing-examples",
  "value-metric-selection",
  "minimum-commitment-model"
]);

const apiPathGuides = pickGuides([
  "api-cost-estimation",
  "api-pricing-model",
  "value-metric-selection"
]);

const storagePathGuides = pickGuides([
  "storage-costs-and-pricing",
  "price-per-gb-month-explained",
  "storage-retrieval-fees"
]);

const computePathGuides = pickGuides([
  "compute-cost-modeling",
  "saas-gross-margin-targets",
  "minimum-commitment-model"
]);

---
<BaseLayout
  title={`Guides | ${siteName}`}
  description="Curated SaaS pricing guides for packaging, pricing page decisions, unit economics, and cost recovery."
>
  <section class="hero">
    <h1>Guides</h1>
    <p>
      Start with the path that matches the pricing decision you are making. This hub is meant to push one retained
      guide path first, not send you browsing a larger guide library.
    </p>
  </section>

  <div class="grid">
    <section class="card col8">
      <h2>Four retained guide paths</h2>
      <p class="muted">Open one path first, then follow only the retained support guides that sharpen the next decision.</p>
      <div class="tools" style="margin-top: 0.9rem;">
        {featuredDecisionGuides.map((guide) => (
          <a class="tool" href={guide.href}>
            <strong>{guide.title}</strong>
            <span>{guide.description}</span>
          </a>
        ))}
      </div>

      <div class="feature-grid" style="margin-top: 1rem;">
        <div class="feature col6">
          <h3>Usage pricing path</h3>
          <ul class="list">
            {usagePathGuides.map((guide) => (
              <li><a href={guide.href}>{guide.title}</a></li>
            ))}
          </ul>
        </div>
        <div class="feature col6">
          <h3>API pricing path</h3>
          <ul class="list">
            {apiPathGuides.map((guide) => (
              <li><a href={guide.href}>{guide.title}</a></li>
            ))}
          </ul>
        </div>
        <div class="feature col6">
          <h3>Storage pricing path</h3>
          <ul class="list">
            {storagePathGuides.map((guide) => (
              <li><a href={guide.href}>{guide.title}</a></li>
            ))}
          </ul>
        </div>
        <div class="feature col6">
          <h3>Compute pricing path</h3>
          <ul class="list">
            {computePathGuides.map((guide) => (
              <li><a href={guide.href}>{guide.title}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <aside class="card col4">
      <h2>Start here</h2>
      <ul class="list">
        <li><a href="/saas-pricing/">All calculators</a></li>
        <li><a href="/glossary/">Core glossary terms</a></li>
        <li><a href="/about/">About the methodology</a></li>
      </ul>

      <h2 style="margin-top: 1.25rem;">How to use this hub</h2>
      <ul class="list">
        <li>Start with one retained guide path instead of browsing the whole inventory.</li>
        <li>Choose the path that matches usage, API, storage, or compute pricing before opening supporting reads.</li>
        <li>Run the linked calculator once you know the pricing question you are solving.</li>
        <li>Use glossary terms only when you need to clarify one concept that blocks the next decision.</li>
      </ul>
    </aside>
  </div>
</BaseLayout>
