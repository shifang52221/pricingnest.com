---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getGuideRobots } from "../../lib/content-governance";

const siteName = import.meta.env.PUBLIC_SITE_NAME ?? "PricingNest";
const entries = await getCollection("guides");
const indexedEntries = entries.filter((entry) => getGuideRobots(entry.slug) === "index,follow");
const guideMap = new Map(
  indexedEntries.map((entry) => [
    entry.slug,
    { slug: entry.slug, href: `/guides/${entry.slug}/`, title: entry.data.title, description: entry.data.description }
  ])
);

function pickGuides(slugs: string[]) {
  return slugs.map((slug) => guideMap.get(slug)).filter(Boolean);
}

const featuredDecisionGuides = pickGuides([
  "value-metric-selection",
  "usage-based-pricing-examples",
  "storage-costs-and-pricing",
  "annual-prepay-discount"
]);

const packagingGuides = pickGuides([
  "pricing-page-layout-checklist",
  "pricing-page-comparison-table",
  "pricing-page-trust-elements",
  "pricing-tier-design",
  "pricing-segmentation"
]);

const unitEconomicsGuides = pickGuides([
  "monthly-cloud-cost-breakdown",
  "compute-cost-modeling",
  "storage-retrieval-fees",
  "price-per-gb-month-explained"
]);

---
<BaseLayout
  title={`Guides | ${siteName}`}
  description="Curated SaaS pricing guides for packaging, pricing page decisions, unit economics, and cost recovery."
>
  <section class="hero">
    <h1>Guides</h1>
    <p>
      Start with the guide closest to the pricing decision you are making. This hub surfaces retained, higher-value
      reading paths first so you do not have to sort through every support page before finding the right next step.
    </p>
  </section>

  <div class="grid">
    <section class="card col8">
      <h2>Featured decision guides</h2>
      <p class="muted">Use these first when you are choosing a pricing model, packaging structure, or annual offer.</p>
      <div class="tools" style="margin-top: 0.9rem;">
        {featuredDecisionGuides.map((guide) => (
          <a class="tool" href={guide.href}>
            <strong>{guide.title}</strong>
            <span>{guide.description}</span>
          </a>
        ))}
      </div>

      <h2 style="margin-top: 1.25rem;">Pricing page and packaging guides</h2>
      <p class="muted">Focus here when the problem is plan clarity, buyer messaging, or feature segmentation.</p>
      <div class="tools" style="margin-top: 0.9rem;">
        {packagingGuides.map((guide) => (
          <a class="tool" href={guide.href}>
            <strong>{guide.title}</strong>
            <span>{guide.description}</span>
          </a>
        ))}
      </div>

      <h2 style="margin-top: 1.25rem;">Unit economics and cost recovery</h2>
      <p class="muted">Use these when you need to back pricing into real compute, storage, and gross-margin constraints.</p>
      <div class="tools" style="margin-top: 0.9rem;">
        {unitEconomicsGuides.map((guide) => (
          <a class="tool" href={guide.href}>
            <strong>{guide.title}</strong>
            <span>{guide.description}</span>
          </a>
        ))}
      </div>
    </section>

    <aside class="card col4">
      <h2>Start here</h2>
      <ul class="list">
        <li><a href="/saas-pricing/">All calculators</a></li>
        <li><a href="/glossary/">Core glossary terms</a></li>
        <li><a href="/about/">About the methodology</a></li>
      </ul>

      <h2 style="margin-top: 1.25rem;">How to use this hub</h2>
      <ul class="list">
        <li>Open one decision guide first instead of comparing many thin support pages.</li>
        <li>Run the linked calculator once you know the pricing question you are solving.</li>
        <li>Use glossary terms only when you need to clarify margin, usage, or packaging language.</li>
      </ul>
    </aside>
  </div>
</BaseLayout>
